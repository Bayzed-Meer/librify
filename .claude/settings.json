{
  "enabledPlugins": {
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/bs01618/personal-projects/librify/.claude/hooks/block_sensitive_files_hook.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/bs01618/personal-projects/librify/.claude/hooks/post_edit_format_hook.py"
          },
          {
            "type": "command",
            "command": "python3 /Users/bs01618/personal-projects/librify/.claude/hooks/post_edit_lint_hook.py"
          }
        ]
      }
    ]
  }
}
